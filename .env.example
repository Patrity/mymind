# Database
DATABASE_URL=postgres://mymind:mymind@localhost:5433/mymind

# Auth
BETTER_AUTH_SECRET=change-me-32-bytes-min
BETTER_AUTH_URL=http://localhost:3000
# Sign-up is disabled by default (single-user, internet-exposed). Set to true
# ONLY to bootstrap your account, then remove it. trustedOrigins derives from BETTER_AUTH_URL.
ALLOW_SIGNUP=

# AI provider roles — OpenAI-spec endpoints (BASE_URL/API_KEY/MODEL per role), env-swappable.
# Defaults below point at the local AI rig (LAN 192.168.2.25). TEI embeddings (8882) works KEYLESS.
# reasoning = the strong chat/extraction model (memory enrichment, transcription cleanup, enrich proposals).
AI_REASONING_BASE_URL=http://192.168.2.25:8004/v1
AI_REASONING_API_KEY=
AI_REASONING_MODEL=qwen3.6-27b-coder
AI_BULK_BASE_URL=http://192.168.2.25:8004/v1
AI_BULK_API_KEY=
AI_BULK_MODEL=qwen3.6-27b-coder
# embeddings = TEI (native /embed, 2560-dim). No key needed.
AI_EMBEDDINGS_BASE_URL=http://192.168.2.25:8882
AI_EMBEDDINGS_API_KEY=
AI_EMBEDDINGS_MODEL=qwen3-embedding-4b
# vision = image OCR / description (8B, weaker + occasionally flaky)
AI_VISION_BASE_URL=http://192.168.2.25:8005/v1
AI_VISION_API_KEY=
AI_VISION_MODEL=qwen3-vl-8b
AI_STT_BASE_URL=http://192.168.2.25:8881/v1
AI_STT_API_KEY=
AI_TTS_BASE_URL=http://192.168.2.25:8880/v1
AI_TTS_API_KEY=
# Optional reranker (Qwen3-Reranker on :8883) for memory-search relevance. OFF unless BASE_URL set.
AI_RERANK_BASE_URL=
AI_RERANK_API_KEY=

# Memory: auto-review (skip human review) when extraction confidence >= this (default 0.75)
MEMORY_AUTO_REVIEW_THRESHOLD=0.75

# Storage
STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR must be a PERSISTENT, writable path (mount a volume in prod). Holds uploaded blobs.
STORAGE_LOCAL_DIR=./.data/uploads
# S3 driver (set STORAGE_DRIVER=s3 to use): endpoint/region/bucket/keys
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Upload limits
# MAX_UPLOAD_BYTES: max accepted upload size in bytes (default 52428800 = 50 MB)
MAX_UPLOAD_BYTES=52428800

# Server (Nitro node-server): port/host the app listens on
NITRO_PORT=3000
NITRO_HOST=0.0.0.0

# Voice agent — browser WebSocket URL of the self-hosted Unmute realtime API.
# Dev (localhost tunnel): ws://localhost:8080/api/v1/realtime
# Prod: wss://<your-domain>/api/v1/realtime   (mic needs HTTPS or localhost)
NUXT_PUBLIC_UNMUTE_URL=ws://localhost:8080/api/v1/realtime
