# Database
DATABASE_URL=postgres://mymind:mymind@localhost:5433/mymind

# Auth
BETTER_AUTH_SECRET=change-me-32-bytes-min
BETTER_AUTH_URL=http://localhost:3000
# Sign-up is disabled by default (single-user, internet-exposed). Set to true
# ONLY to bootstrap your account, then remove it. trustedOrigins derives from BETTER_AUTH_URL.
ALLOW_SIGNUP=

# AI providers/models are configured in the app at /settings (stored encrypted in the DB).
# Optional: a 32-byte base64 key to encrypt provider API keys. If unset, a key is
# derived from BETTER_AUTH_SECRET. Set this only if you want key rotation independent of auth.
# CONFIG_ENC_KEY=

# Memory: auto-review (skip human review) when extraction confidence >= this (default 0.75)
MEMORY_AUTO_REVIEW_THRESHOLD=0.75

# Storage
STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR must be a PERSISTENT, writable path (mount a volume in prod). Holds uploaded blobs.
STORAGE_LOCAL_DIR=./.data/uploads
# S3 driver (set STORAGE_DRIVER=s3 to use): endpoint/region/bucket/keys
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Upload limits
# MAX_UPLOAD_BYTES: max accepted upload size in bytes (default 52428800 = 50 MB)
MAX_UPLOAD_BYTES=52428800

# Server (Nitro node-server): port/host the app listens on
NITRO_PORT=3000
NITRO_HOST=0.0.0.0

# Search — SearXNG is bundled in docker-compose.prod.yml. The app reaches it internally
# on the compose network; the app defaults to this URL (override in-app at /settings → Search).
SEARCH_SEARXNG_URL=http://searxng:8080
# Host port SearXNG is published on for OTHER homelab services to share (LAN-only —
# do not expose to the internet). Other services point at http://<lxc-ip>:${SEARXNG_PORT}.
SEARXNG_PORT=8088
# Secret key for the SearXNG instance. REQUIRED in prod — compose passes this to the
# container and its entrypoint injects it at boot. Generate: openssl rand -hex 32
SEARXNG_SECRET=change-me-in-prod

